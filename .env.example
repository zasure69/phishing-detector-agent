GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
# Optional: only needed if using agent identity features
GREENNODE_AGENT_IDENTITY=

# ── LLM provider (GreenNode MaaS / AI Platform — OpenAI-compatible) ──
# Get an API key with /agentbase-llm api-keys create
LLM_API_KEY=
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1

# Model IDs — use the `path` field from /agentbase-llm models list (must be ENABLED).
QWEN_MODEL=qwen/qwen3-5-27b
GEMMA_MODEL=google/gemma-4-31b-it
MINIMAX_MODEL=minimax/minimax-m2.5

# Pipeline tuning (optional)
LLM_TIMEOUT_SECONDS=60
MINIMAX_ENABLED=true
# Disable models' hidden "thinking" trace. Required for Qwen 3.5 — otherwise it
# spends the whole token budget reasoning and returns empty content. Keep true.
DISABLE_THINKING=true
